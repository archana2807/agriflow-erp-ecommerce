{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://agriflow-erp-ecommerce.onrender.com/api/$1"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "https://agriflow-erp-ecommerce.onrender.com/uploads/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}